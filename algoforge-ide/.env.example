# Copy to .env and adjust as needed. The server reads these at startup.

# Port the Express file/execution API listens on.
PORT=3001

# --- File source -----------------------------------------------------------
# Where the algorithm files are read from: "disk" (local) or "blob" (Azure).
FILE_SOURCE=disk

# disk: repo root to serve. Defaults to the checkout (two levels up from server/).
# LOCAL_REPO_ROOT=C:\Users\you\repos\Summary

# blob: Azure Blob Storage settings (used only when FILE_SOURCE=blob).
# Prefer AZURE_STORAGE_ACCOUNT_URL + managed identity in Azure; connection string for local tests.
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_ACCOUNT_URL=https://<account>.blob.core.windows.net
AZURE_STORAGE_CONTAINER=algorithms
FILE_ROOT_NAME=Algorithms

# Comma-separated CORS origins allowed to call the API (the frontend URL).
# Empty = same-origin only (fine for local dev via the Vite proxy). "*" = any origin.
# Example: https://gentle-bush-0e37b3e0f.7.azurestaticapps.net
ALLOWED_ORIGINS=

# Top-level folders shown under "Companies" (comma-separated).
COMPANY_FOLDERS=Amazon

# --- GitHub sync (optional) -------------------------------------------------
# Commits app-created problems/solutions back into the repo (Blob -> git).
# These are defaults; they can also be set at runtime from the web GitHub dialog.
# GITHUB_REPO=Ivesonchen/Summary
# GITHUB_BRANCH=master
# Dedicated integration branch that sync commits land on (PR head into GITHUB_BRANCH).
# GITHUB_SYNC_BRANCH=algoforge-sync
# Fine-grained PAT with Contents: read & write and Pull requests: read & write. Kept server-side; never sent to the browser.
# GITHUB_TOKEN=

# URL of the Piston sandbox that actually runs submitted code.
# Local dev (docker compose up piston): http://localhost:2000
# Azure: the private host address, reachable only from the API subnet.PISTON_URL=http://localhost:2000

# Per-run sandbox limits.
RUN_WALL_TIME_LIMIT=10          # seconds; becomes Piston run_timeout
RUN_COMPILE_TIMEOUT_MS=10000    # ms; Piston compile_timeout
RUN_MEMORY_LIMIT_BYTES=-1       # bytes; -1 = unlimited (avoids JVM/compiler OOM)

# Optional per-language Piston version pins (default: newest installed).
# PISTON_VER_JAVA=15.0.2
# PISTON_VER_PYTHON=3.12.0
# PISTON_VER_JAVASCRIPT=20.11.1
# PISTON_VER_TYPESCRIPT=5.0.3
# PISTON_VER_CPP=10.2.0
# PISTON_VER_C=10.2.0
# PISTON_VER_GO=1.16.2

# --- AI chat (optional) -----------------------------------------------------
# Powers the in-app "AI Assistant" tab via the GitHub Models API.
# Token is held server-side only and never sent to the browser.
# Use a GitHub PAT with the "Models" permission (falls back to GITHUB_TOKEN).
# GITHUB_MODELS_TOKEN=
# Model id to use (default openai/gpt-4o-mini). See https://github.com/marketplace/models
# GITHUB_MODELS_MODEL=openai/gpt-4o-mini
# Override the inference endpoint if needed.
# GITHUB_MODELS_URL=https://models.github.ai/inference/chat/completions

# --- AI provider selection --------------------------------------------------
# Which backend powers the AI Chat tab:
#   github-models (default) — GitHub Models inference API (PAT above).
#   copilot                 — GitHub Copilot via the official CLI/SDK. Binds to
#                             a SINGLE account: an operator signs in once from
#                             the Chat tab (device flow). Chat-only (all agent
#                             tools are denied). Requires @github/copilot-sdk.
# AI_PROVIDER=copilot
# Optional model id for the copilot provider (must be one your Copilot plan
# offers, e.g. a Claude/GPT model shown in the editor model picker).
# COPILOT_MODEL=
# Copilot response timeout in ms (default 120000).
# COPILOT_CHAT_TIMEOUT_MS=120000
#
# NOTE (Azure): the copilot provider stores its token in ~/.copilot on the
# server. In a scale-to-zero / ephemeral Container App the token is lost on
# restart, forcing re-sign-in. For a robust deployment use minReplicas=1 and
# mount persistent storage for the home dir, and ensure the Linux CLI binary
# (@github/copilot-linux-x64) ships in the image.